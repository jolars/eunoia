import DiagramExample from "$lib/components/DiagramExample.svelte";

const FOUR_SET_SPEC = {
  A: 10, B: 10, C: 10, D: 10,
  "A&B": 4, "A&C": 4, "A&D": 4,
  "B&C": 4, "B&D": 4, "C&D": 4,
  "A&B&C": 1.5, "A&B&D": 1.5, "A&C&D": 1.5, "B&C&D": 1.5,
  "A&B&C&D": 0.5,
};
