{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "rootDir": ".",
    "outDir": "../npm"
  },
  "include": ["index.ts"]
}
