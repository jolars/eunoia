{
  "name": "@jolars/eunoia",
  "version": "1.5.0",
  "description": "Area-proportional Euler and Venn diagrams",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "author": "Johan Larsson",
  "homepage": "https://github.com/jolars/eunoia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jolars/eunoia.git"
  },
  "bugs": {
    "url": "https://github.com/jolars/eunoia/issues"
  },
  "keywords": [
    "euler",
    "venn",
    "diagram",
    "visualization",
    "wasm",
    "webassembly"
  ],
  "type": "module",
  "main": "index.js",
  "module": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./svg": {
      "types": "./svg.d.ts",
      "default": "./svg.js"
    },
    "./web": {
      "types": "./web.d.ts",
      "default": "./web.js"
    },
    "./trajectory": {
      "types": "./trajectory.d.ts",
      "default": "./trajectory.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "svg.js",
    "svg.d.ts",
    "web.js",
    "web.d.ts",
    "trajectory.js",
    "trajectory.d.ts",
    "eunoia_wasm.js",
    "eunoia_wasm.d.ts",
    "eunoia_wasm_bg.js",
    "eunoia_wasm_bg.wasm",
    "eunoia_wasm_bg.wasm.d.ts"
  ],
  "sideEffects": [
    "./eunoia_wasm.js",
    "./snippets/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "~6.0.3"
  }
}
